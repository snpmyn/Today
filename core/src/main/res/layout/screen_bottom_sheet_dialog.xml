<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="@dimen/dp_10"
        android:paddingRight="@dimen/dp_10">

        <com.google.android.material.bottomsheet.BottomSheetDragHandleView
            android:id="@+id/screenBottomSheetDialogBsdhv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/screenBottomSheetDialogMd"
            android:layout_width="match_parent"
            android:layout_height="@dimen/px1"
            android:layout_below="@+id/screenBottomSheetDialogBsdhv"
            app:dividerInsetEnd="@dimen/dp_12"
            app:dividerInsetStart="@dimen/dp_12" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/screenBottomSheetDialogMbReset"
            style="@style/Widget.MaterialComponents.Button.TextButton.Dialog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/screenBottomSheetDialogMd"
            android:filterTouchesWhenObscured="true"
            android:text="@string/reset"
            android:textSize="@dimen/sp_13"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/screenBottomSheetDialogMbEnsure"
            style="@style/Widget.MaterialComponents.Button.TextButton.Dialog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/screenBottomSheetDialogMd"
            android:layout_alignParentEnd="true"
            android:filterTouchesWhenObscured="true"
            android:text="@string/ensure"
            android:textSize="@dimen/sp_13"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/screenBottomSheetDialogRv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none" />
</LinearLayout>