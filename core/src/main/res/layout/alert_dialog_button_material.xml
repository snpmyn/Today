<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/buttonMaterialAlertDialogMcvTop"
        style="?attr/materialCardViewFilledStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_12"
        android:layout_marginTop="@dimen/dp_20"
        android:layout_marginBottom="@dimen/dp_20"
        app:contentPadding="@dimen/dp_12">

        <TextView
            android:id="@+id/buttonMaterialAlertDialogTvTop"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:lineSpacingExtra="@dimen/dp_6"
            android:textSize="@dimen/sp_14"
            android:textStyle="bold"
            tools:text="上" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/buttonMaterialAlertDialogMcvMiddle"
        style="?attr/materialCardViewFilledStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_12"
        android:layout_marginBottom="@dimen/dp_20"
        app:contentPadding="@dimen/dp_12">

        <TextView
            android:id="@+id/buttonMaterialAlertDialogTvMiddle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:lineSpacingExtra="@dimen/dp_6"
            android:textSize="@dimen/sp_14"
            android:textStyle="bold"
            tools:text="中" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/buttonMaterialAlertDialogMcvBottom"
        style="?attr/materialCardViewFilledStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dp_12"
        android:layout_marginBottom="@dimen/dp_20"
        app:contentPadding="@dimen/dp_12">

        <TextView
            android:id="@+id/buttonMaterialAlertDialogTvBottom"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:lineSpacingExtra="@dimen/dp_6"
            android:textSize="@dimen/sp_14"
            android:textStyle="bold"
            tools:text="下" />
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>