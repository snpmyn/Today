<?xml version="1.0" encoding="utf-8"?>
<litepal>
    <!--
    	Define the com.zsp.today.database name of your com.zsp.today.application.
    	By default each com.zsp.today.database name should be end with .db.
    	If you didn't name your com.zsp.today.database end with .db,
    	LitePal would plus the suffix automatically for you.
    	For example:
    	<dbname value="demo" />
    -->
    <dbname value="today" />

    <!--
    	Define the version of your com.zsp.today.database. Each time you want
    	to upgrade your com.zsp.today.database, the version tag would helps.
    	Modify the models you defined in the mapping tag, and just
    	make the version value plus one, the upgrade of com.zsp.today.database
    	will be processed automatically without concern.
		For example:
    	<version value="1" />
    -->
    <version value="1" />

    <!--
    	Define your models in the list with mapping tag, LitePal will
    	create tables for each mapping class. The supported fields
    	defined in models will be mapped into columns.
    	For example:
    	<list>
    		<mapping class="com.test.model.Reader" />
    		<mapping class="com.test.model.Magazine" />
    	</list>
    -->
    <list>
        <!--用户数据库表-->
        <mapping class="com.zsp.today.module.login.UserDataBaseTable" />
        <!--功能数据库表-->
        <mapping class="com.zsp.today.module.function.database.FunctionDataBaseTable" />
        <!--账目数据库表-->
        <mapping class="com.zsp.today.module.account.database.AccountDataBaseTable" />
        <!--险情数据库表-->
        <mapping class="com.zsp.today.module.dangerous.database.DangerousDataBaseTable" />
        <!--归心数据库表-->
        <mapping class="com.zsp.today.module.homecome.database.HomeComeDataBaseTable" />"
    </list>

    <!--
        Define where the .db file should be. "internal" means the .db file
        will be stored in the com.zsp.today.database folder of internal storage which no
        one can access. "external" means the .db file will be stored in the
        path to the directory on the primary external storage device where
        the com.zsp.today.application can place persistent files it owns which everyone
        can access. "internal" will act as default.
        For example:
    -->
    <!--若两 APP 都设 external 且有同名数据库表，则该两 APP 可互访对方数据库表，导致数据污染。与数据库名无关-->
    <storage value="internal" />
</litepal>