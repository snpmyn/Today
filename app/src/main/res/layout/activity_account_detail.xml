<?xml version="1.0" encoding="utf-8"?>
<widget.coordinatorlayout.DraggableCoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/accountDetailActivityDcl"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".module.account.AccountDetailActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/accountDetailActivityMt"
            style="@style/Widget.MaterialComponents.Toolbar.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:menu="@menu/account_detail_activity_menu"
            app:navigationIcon="@drawable/ic_arrow_back_white_24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/accountDetail"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_16" />
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/accountDetailActivityRv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/pageBackground"
        android:scrollbars="none"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/accountDetailActivityFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/dp_24"
        android:layout_marginBottom="@dimen/dp_24"
        android:contentDescription="@string/everydayAnalysis"
        app:fabSize="mini"
        app:maxImageSize="@dimen/dp_18"
        app:srcCompat="@drawable/ic_graph_white_18dp"
        app:tint="@color/white" />

    <com.google.android.material.transformation.TransformationChildCard
        android:id="@+id/accountDetailActivityTcc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="@dimen/dp_12"
        android:visibility="invisible"
        app:cardElevation="@dimen/dp_6"
        app:layout_behavior="@string/fab_transformation_sheet_behavior">

        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/accountDetailActivityPc"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_276"
            android:layout_margin="@dimen/dp_2" />

        <ImageButton
            android:id="@+id/accountDetailActivityIb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="@dimen/dp_12"
            android:layout_marginEnd="@dimen/dp_12"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/closeEverydayAnalysis"
            app:srcCompat="@drawable/ic_close_purple_500_24dp" />
    </com.google.android.material.transformation.TransformationChildCard>
</widget.coordinatorlayout.DraggableCoordinatorLayout>