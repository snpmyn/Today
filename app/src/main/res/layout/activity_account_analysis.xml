<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".module.account.AccountAnalysisActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/accountAnalysisActivityMt"
        style="@style/Widget.MaterialComponents.Toolbar.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:menu="@menu/account_analysis_activity_menu"
        app:navigationIcon="@drawable/ic_arrow_back_white_24dp"
        app:title="@string/accountAnalysis"
        app:titleTextColor="@color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_0"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/accountAnalysisActivityMt">

        <TextView
            android:id="@+id/accountAnalysisActivityTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/dp_12"
            android:textColor="@color/basic"
            android:textSize="@dimen/sp_14"
            android:textStyle="bold"
            tools:text="月度分析" />

        <com.google.android.material.card.MaterialCardView
            style="?attr/materialCardViewFilledStyle"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_0"
            android:layout_margin="@dimen/dp_12"
            android:layout_weight="1"
            app:cardElevation="@dimen/dp_0"
            app:contentPadding="@dimen/dp_12">

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/accountAnalysisActivityLcMonthAnalysis"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/accountAnalysisActivityLcYearAnalysis"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />
        </com.google.android.material.card.MaterialCardView>

        <Space
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_0"
            android:layout_weight="1" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>