<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/basic"
        app:layout_constraintBottom_toTopOf="@+id/accountHomeActivityBottomSheetDialogLlAccountAnalysis"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/accountHomeActivityBottomSheetDialogLlAccountAnalysis"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="@dimen/dp_12"
        android:paddingTop="@dimen/dp_24"
        android:paddingRight="@dimen/dp_12"
        android:paddingBottom="@dimen/dp_24"
        app:layout_constraintBottom_toBottomOf="parent">

        <widget.textview.DrawableCenterTextView
            android:id="@+id/accountHomeActivityBottomSheetDialogDctvAccountAnalysis"
            android:layout_width="@dimen/dp_0"
            android:layout_height="?actionBarSize"
            android:layout_weight="1"
            android:drawableTop="@drawable/ic_account_analysis_basic_20dp"
            android:drawablePadding="@dimen/dp_10"
            android:gravity="center_horizontal"
            android:text="@string/accountAnalysis"
            android:textSize="@dimen/sp_14" />

        <widget.textview.DrawableCenterTextView
            android:id="@+id/accountHomeActivityBottomSheetDialogDctvExportAccount"
            android:layout_width="@dimen/dp_0"
            android:layout_height="?actionBarSize"
            android:layout_weight="1"
            android:drawableTop="@drawable/ic_export_account_basic_20dp"
            android:drawablePadding="@dimen/dp_10"
            android:gravity="center_horizontal"
            android:text="@string/exportAccount"
            android:textSize="@dimen/sp_14" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>