<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".module.account.AccountSecondActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/accountSecondActivityMt"
        style="@style/Widget.Material3.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="?actionBarSize"
        android:background="?attr/colorSurface"
        app:menu="@menu/account_second_activity_menu"
        app:titleTextAppearance="@style/TextAppearance.Material3.TitleMedium.Emphasized" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/accountSecondActivityRv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/accountSecondActivityMt"
        android:scrollbars="none" />
</RelativeLayout>