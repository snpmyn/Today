WeakReference<AppCompatActivity> weakReference = new WeakReference<>(appCompatActivity);
        final String[] value = new String[1];
        new MyMaterialAlertDialogBuilder(weakReference.get())
                .setNeutralButton(weakReference.get().getString(R.string.cancel), (dialog, which) -> dialog.dismiss())
                .setPositiveButton(weakReference.get().getString(R.string.ok), (dialog, which) -> {
                    dialog.dismiss();
                    singleChooseKitInterface.value(value[0]);
                })
                // Single-choice items (initialized with checked item)
                .setSingleChoiceItems(items, checkedItem, (dialog, which) -> value[0] = (String) items[which]).show();

